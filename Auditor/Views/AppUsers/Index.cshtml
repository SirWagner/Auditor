@model IEnumerable<Auditor.Models.AppUser>

@{
    ViewData["Title"] = "Users";
}

<link rel="stylesheet" href="~/claudedesign/appusers.css" />

<div style="padding: 2rem 2.5rem; min-height: 100vh; background: var(--bg);">

    <div class="page-header">
        <div class="page-header-left">
            <div class="page-tag">Access Management</div>
            <h1>System <span>Users</span></h1>
        </div>
        <a asp-action="Create" class="btn-new">+ New User</a>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.DisplayName</td>
                        <td style="color: var(--text-muted);">@user.Email</td>
                        <td>
                            @{
                                var roleCss = user.Role switch {
                                    "Admin"   => "badge badge-admin",
                                    "Auditor" => "badge badge-auditor",
                                    _         => "badge badge-viewer"
                                };
                            }
                            <span class="@roleCss">@(user.Role ?? "—")</span>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Inactive</span>
                            }
                        </td>
                        <td style="color: var(--text-muted); font-size: 0.85rem;">
                            @user.CreatedDate.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn-icon" title="Edit">✏️</a>
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn-icon" title="Details">🔍</a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn-icon danger" title="Delete">🗑️</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding: 3rem; color: var(--text-muted);">
                            No users found. <a asp-action="Create" style="color: var(--primary);">Create the first one</a>.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
