@model IEnumerable<Auditor.Models.ScheduleChangeRequest>

@{
    ViewData["Title"] = "Schedule Change Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentStatus = ViewBag.CurrentStatus as string ?? "Pending";
}

<div class="list-container">
    <div class="list-header">
        <div class="list-header-content">
            <h1>🔄 Schedule Change Requests</h1>
            <p class="list-header-subtitle">Review and authorize requested changes to audit schedules</p>
        </div>
    </div>

    <div class="mb-3">
        @foreach (var s in new[] { "Pending", "Approved", "Rejected", "All" })
        {
            <a asp-action="Index" asp-route-status="@s"
               class="btn @(s == currentStatus ? "btn-primary" : "btn-outline-secondary") btn-sm me-1">@s</a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="list-table-wrapper">
            <table class="list-table table">
                <thead>
                    <tr>
                        <th>Schedule</th>
                        <th>Requested By</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Escalation</th>
                        <th>Requested Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Schedule != null ? $"#{item.Schedule.Id}" : "-")</td>
                            <td>@(item.RequestedByNavigation?.DisplayName ?? "Unknown")</td>
                            <td>@item.Reason</td>
                            <td><span class="status-badge">@item.Status</span></td>
                            <td>@(item.EscalationLevel ?? 0)</td>
                            <td>@item.RequestDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="list-table-wrapper">
            <div class="list-empty-state">
                <div class="empty-state-icon">✅</div>
                <h2 class="empty-state-title">No Change Requests</h2>
                <p class="empty-state-text">There are no change requests matching this filter.</p>
            </div>
        </div>
    }
</div>
