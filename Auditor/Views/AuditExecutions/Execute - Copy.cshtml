@model Auditor.ViewModels.AuditExecution.AuditExecutionRenderViewModel

@{
    ViewData["Title"] = "Execute Audit";
    Layout = "~/Views/Shared/_LayoutExec.cshtml";
}

<h2>@Model.AuditName</h2>
<h4>Site: @Model.SiteName</h4>

<hr />

<div class="mb-3">
    <a asp-action="Index" asp-controller="AuditSchedule">
        Back to Scheduled Audits
    </a>
</div>

<form id="auditForm" enctype="multipart/form-data">

    @foreach (var question in Model.Questions)
    {
        <div class="card mb-3">
            <div class="card-body">

                <h5>
                    @question.QuestionText
                    @if (question.IsMandatory)
                    {
                        <span class="text-danger">*</span>
                    }
                </h5>

                @await Html.PartialAsync(
                $"~/Views/AuditExecutions/Components/_"
                + question.QuestionTypeName
                + ".cshtml",
                        question)

                <div class="mt-2">
                    <label>Attachments</label>
                    <input type="file" name="questionAttachments[@question.TemplateItemId][]" multiple class="form-control" />
                </div>

        </div>
    </div>
        }

    <div class="mt-3">
        <button type="button"
                class="btn btn-success"
                onclick="submitAudit(@Model.ExecutionId)">
            Submit Audit
        </button>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/audit-render.js"></script>
}