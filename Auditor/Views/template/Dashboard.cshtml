@model Auditor.ViewModels.Dashboard.DashboardViewModel

@{
    if (User.IsInRole("Viewer"))
    {
        ViewData["Title"] = "Audit Executions";
        Layout = "~/Views/Shared/_LayoutViewer.cshtml";
        ViewData["HideHeader"] = true;
    }
    else
    {
        ViewData["Title"] = "Dashboard";
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

<div class="list-container">
    <div class="list-header">
        <div class="list-header-content">
            <h1>📊 Dashboard</h1>
            <p class="list-header-subtitle">Hi, welcome back @User.Identity?.Name — here's the current state of the audit program.</p>
        </div>
    </div>

    <div class="dashboard-stats-grid">
        <div class="stat-tile">
            <div class="stat-tile-value">@Model.ActiveAuditors <span class="stat-tile-of">/ @Model.TotalAuditors</span></div>
            <div class="stat-tile-label">Active Auditors</div>
        </div>
        <div class="stat-tile">
            <div class="stat-tile-value">@Model.ActiveTemplates <span class="stat-tile-of">/ @Model.TotalTemplates</span></div>
            <div class="stat-tile-label">Active Templates</div>
        </div>
        <div class="stat-tile">
            <div class="stat-tile-value">@Model.ActiveSites <span class="stat-tile-of">/ @Model.TotalSites</span></div>
            <div class="stat-tile-label">Active Sites</div>
        </div>
        <div class="stat-tile @(Model.OverdueSchedules > 0 ? "stat-tile-warning" : "")">
            <div class="stat-tile-value">@Model.OverdueSchedules</div>
            <div class="stat-tile-label">Overdue Schedules</div>
        </div>
        <div class="stat-tile @(Model.PendingChangeRequests > 0 ? "stat-tile-warning" : "")">
            <div class="stat-tile-value">@Model.PendingChangeRequests</div>
            <div class="stat-tile-label">Pending Change Requests</div>
        </div>
    </div>

    <div class="dashboard-breakdown-row">
        <div class="details-info-card">
            <div class="details-info-card-header">
                <i class="typcn typcn-calendar-outline"></i>
                <h2>Schedules</h2>
            </div>
            <div class="details-info-card-body">
                <div class="details-info-grid">
                    <div class="details-info-field">
                        <div class="details-info-label">Scheduled</div>
                        <div class="details-info-value"><strong>@Model.ScheduledAudits</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">Cancelled</div>
                        <div class="details-info-value"><strong>@Model.CancelledSchedules</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">Overdue</div>
                        <div class="details-info-value"><strong>@Model.OverdueSchedules</strong></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="details-info-card">
            <div class="details-info-card-header">
                <i class="typcn typcn-flash-outline"></i>
                <h2>Executions</h2>
            </div>
            <div class="details-info-card-body">
                <div class="details-info-grid">
                    <div class="details-info-field">
                        <div class="details-info-label">Pending Acceptance</div>
                        <div class="details-info-value"><strong>@Model.ExecutionsPendingAcceptance</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">In Progress</div>
                        <div class="details-info-value"><strong>@Model.ExecutionsInProgress</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">Completed</div>
                        <div class="details-info-value"><strong>@Model.ExecutionsCompleted</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">Closed</div>
                        <div class="details-info-value"><strong>@Model.ExecutionsClosed</strong></div>
                    </div>
                    <div class="details-info-field">
                        <div class="details-info-label">Rejected</div>
                        <div class="details-info-value"><strong>@Model.ExecutionsRejected</strong></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="list-header" style="margin-top: 24px;">
        <div class="list-header-content">
            <h2 style="margin:0;">Recent Executions</h2>
        </div>
    </div>

    @if (Model.RecentExecutions.Any())
    {
        <div class="list-table-wrapper">
            <table class="list-table table">
                <thead>
                    <tr>
                        <th>Template</th>
                        <th>Site</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentExecutions)
                    {
                        var statusClass = item.Status switch
                        {
                            "COMPLETED" or "CLOSED" => "active",
                            "REJECTED" => "inactive",
                            _ => "warning"
                        };
                        <tr>
                            <td><div class="cell-name">@item.TemplateName</div></td>
                            <td><div class="cell-secondary">@item.SiteName</div></td>
                            <td><span class="details-status-badge @statusClass">@item.Status</span></td>
                            <td><div class="cell-secondary">@item.Date.ToString("MMM dd, yyyy")</div></td>
                            <td>
                                <a asp-controller="AuditExecutions" asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="list-table-wrapper">
            <div class="list-empty-state">
                <div class="empty-state-icon">🚀</div>
                <h2 class="empty-state-title">No Executions Yet</h2>
                <p class="empty-state-text">Once audits start being executed, recent activity will show up here.</p>
            </div>
        </div>
    }
</div>
