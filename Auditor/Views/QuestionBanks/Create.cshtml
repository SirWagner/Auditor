@model Auditor.Models.QuestionBank

@{
    ViewData["Title"] = "Create Question";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="list-container">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Question Bank</a></li>
        <li class="breadcrumb-item active">Create Question</li>
    </ol>
</nav>

<div class="list-container">
    <div class="form-wrapper">

        <!-- Header -->
        <div class="mb-4">
            <h1 class="h2 d-flex align-items-center gap-2">
                <i class="fas fa-plus-circle text-primary"></i>
                Create New Audit Question
            </h1>
            <p class="list-header-subtitle mb-0">
                Add a new question to your audit question bank for consistent airport evaluations.
            </p>
        </div>

        <hr class="mb-4" />

        <!-- Form -->
        <form asp-action="Create" method="post" class="form-content">
            @Html.AntiForgeryToken()

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert">
                <strong>Please correct the following errors:</strong>
            </div>

            <!-- Question Text -->
            <div class="mb-3">
                <label asp-for="QuestionText" class="form-label fw-semibold">
                    <i class="fas fa-comment-dots text-primary me-1"></i>
                    Question Text
                </label>
                <textarea asp-for="QuestionText" class="form-control" rows="4"
                          placeholder="Enter the audit question..." required></textarea>
                <span asp-validation-for="QuestionText" class="text-danger small"></span>
            </div>

            <!-- Category + Type -->
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold">
                        <i class="fas fa-folder-open text-primary me-1"></i>
                        Category
                    </label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="ViewBag.CategoryId" required>
                        <option value="">-- Select a category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="QuestionTypeId" class="form-label fw-semibold">
                        <i class="fas fa-list text-primary me-1"></i>
                        Question Type
                    </label>
                    <select asp-for="QuestionTypeId" class="form-select"
                            asp-items="ViewBag.QuestionTypeId" required>
                        <option value="">-- Select a type --</option>
                    </select>
                    <span asp-validation-for="QuestionTypeId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Service Standard -->
            <div class="mt-3">
                <label asp-for="ServiceStandardRecommendation" class="form-label fw-semibold">
                    <i class="fas fa-star text-warning me-1"></i>
                    Service Standard Recommendation
                </label>
                <textarea asp-for="ServiceStandardRecommendation"
                          class="form-control"
                          rows="3"
                          placeholder="Describe expected service standard..." required></textarea>
                <div class="form-text">
                    Provide guidance on what constitutes compliance.
                </div>
                <span asp-validation-for="ServiceStandardRecommendation" class="text-danger small"></span>
            </div>

            <!-- Contractor -->
            <div class="mt-3">
                <label asp-for="ResponsibleContractor" class="form-label fw-semibold">
                    <i class="fas fa-user-tie text-primary me-1"></i>
                    Responsible Contractor/Department
                </label>
                <input asp-for="ResponsibleContractor"
                       class="form-control"
                       placeholder="Enter responsible entity" required />
                <div class="form-text">
                    Who is accountable for this audit area.
                </div>
                <span asp-validation-for="ResponsibleContractor" class="text-danger small"></span>
            </div>

            <!-- Created By -->
            <div class="mt-3">
                <label asp-for="CreatedBy" class="form-label fw-semibold">
                    <i class="fas fa-user-circle text-primary me-1"></i>
                    Audit Coordinator
                </label>
                <select asp-for="CreatedBy"
                        class="form-select"
                        asp-items="ViewBag.CreatedBy" required>
                    <option value="">-- Select an auditor --</option>
                </select>
                <span asp-validation-for="CreatedBy" class="text-danger small"></span>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a asp-action="Index" class="btn btn-secondary-action">
                    <i class="fas fa-arrow-left me-1"></i>
                    Cancel
                </a>

                <button type="submit" class="btn btn-list-primary">
                    <i class="fas fa-check-circle me-1"></i>
                    Create Question
                </button>
            </div>

        </form>

        <!-- Info -->
        <div class="alert alert-info mt-4 mb-0">
            <i class="fas fa-info-circle me-1"></i>
            <strong>Tip:</strong> Ensure questions are clear, measurable, and aligned with airport standards.
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form');
            if (!form) return;

            const submitBtn = form.querySelector('button[type="submit"]');

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                // Check jQuery validation if using _ValidationScriptsPartial
                if (typeof $(form).valid === 'function' && !$(form).valid()) {
                    return;
                }

                if (submitBtn.disabled) return;

                submitBtn.disabled = true;
                submitBtn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Creating...`;

                try {
                    const formData = new FormData(form);
                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (response.ok) {
                        const result = await response.json();
                        if (result.success) {
                            // SUCCESS: Show SweetAlert
                            Swal.fire({
                                title: 'Question Created!',
                                text: result.message,
                                icon: 'success',
                                confirmButtonColor: '#0ea5a8', // Matches your --accent-teal
                                confirmButtonText: 'Great!'
                            });

                            // Clear the form and validation messages
                            form.reset();
                            document.querySelectorAll('.invalid-feedback').forEach(s => s.textContent = '');
                
                            resetButton();
                        }
                    } else {
                        // ERROR: Handle server-side validation (400 Bad Request)
                        const errors = await response.json();
                        handleErrors(errors);
            
                        Swal.fire({
                            title: 'Validation Error',
                            text: 'Please check the highlighted fields and try again.',
                            icon: 'error',
                            confirmButtonColor: '#ef4444' // Matches your --danger color
                        });
            
                        resetButton();
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    resetButton();
                }
        });

            function resetButton() {
                submitBtn.disabled = false;
                submitBtn.innerHTML = `
                    <i class="fas fa-check-circle me-1"></i>
                    Create Question
                `;
            }

            function handleErrors(errors) {
                // clear old errors
                document.querySelectorAll('[data-valmsg-for]').forEach(span => {
                    span.textContent = '';
                });

                for (const key in errors) {
                    const span = document.querySelector(`[data-valmsg-for="${key}"]`);
                    if (span && errors[key].errors.length > 0) {
                        span.textContent = errors[key].errors[0].errorMessage;
                    }
                }
            }
        });
    </script>
}