@model IEnumerable<Auditor.Models.AuditExecution>

@{
    ViewData["Title"] = "Audit Executions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="list-container">
    <div class="list-header">
        <div class="list-header-content">
            <h1>⚙️ Audit Executions</h1>
            <p class="list-header-subtitle">Perform and track live audit sessions</p>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="list-table-wrapper">
            <table class="list-table table execution-table">
                <thead>
                    <tr>
                        <th style="width: 25%;">Audit Template</th>
                        <th style="width: 20%;">Site</th>
                        <th style="width: 20%;">Scheduled Date</th>
                        <th style="width: 15%;">Status</th>
                        <th style="width: 20%;">Actions</th>
                    </tr>
                </thead>
                <tbody id="executionTableBody">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="cell-name">
                                    @item.Schedule.Template.Name
                                </div>
                            </td>
                            <td>
                                <div class="cell-secondary">
                                    <span class="cell-code">@item.Schedule.Site.Name</span>
                                </div>
                            </td>
                            <td>
                                <div class="cell-secondary">
                                    @item.Schedule.ScheduledDate.ToString("MMM dd, yyyy")
                                    <br />
                                    <small class="text-muted">@item.Schedule.ScheduledDate.ToString("t")</small>
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusClass = item.Status?.ToString().ToLower() == "completed"
                                        ? "status-active"
                                        : "status-inactive";
                                }
                                <span class="status-badge @statusClass">@item.Status</span>
                            </td>
                            <td>
                                <div class="list-actions">
                                    <a asp-controller="AuditExecutions"
                                           asp-action="Execute"
                                           asp-route-executionId="@item.Id"
                                           class="action-btn btn-edit"
                                           style="background-color: #28a745; color: white; border-color: #28a745;">
                                        Continue
                                    </a>

                                    <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="action-btn btn-view">
                                        Details
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
    }
    else
    {
        <div class="list-table-wrapper">
            <div class="list-empty-state">
                <div class="empty-state-icon">🚀</div>
                <h2 class="empty-state-title">No Active Executions</h2>
                <p class="empty-state-text">There are no audits currently being executed.</p>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            Paginator.init({
                tableBodyId: "executionTableBody",
                paginationId: "executionPagination",
                rowsPerPage: 5
            });
        });
    </script>
}