@model Auditor.Models.QuestionBankOption

@{
    ViewData["Title"] = "Create Question Bank Option";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-page-container">
    <div class="form-page-breadcrumb">
        <a asp-controller="Template" asp-action="Dashboard">Dashboard</a>
        <span>›</span>
        <a asp-controller="QuestionBankOptions" asp-action="Index">Question Bank Options</a>
        <span>›</span>
        <span>Create New</span>
    </div>

    <div class="form-page-title-section">
        <div class="form-page-title-content">
            <h1>Create Answer Option</h1>
            <p>Add a selectable answer choice for a multiple-choice or checklist question</p>
        </div>
        <div class="form-page-meta">
            <span class="form-meta-badge">New Entry</span>
        </div>
    </div>

    <div class="form-wrapper">
        <div class="form-main">
            <div class="form-main-header">
                <h2>
                    <i class="fas fa-list-ol"></i>
                    Option Details
                </h2>
            </div>

            <div class="form-main-content">
                <form asp-action="Create" method="post" novalidate id="createOptionForm">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="validation-alert">
                            <h3>
                                <i class="fas fa-times-circle"></i>
                                Form Validation Errors
                            </h3>
                            <ul>
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <div class="form-section">
                        <h3 class="form-section-title">Belongs To</h3>

                        <div class="form-grid full">
                            <div class="form-group">
                                <label asp-for="QuestionBankId">
                                    Question
                                    <span class="required">*</span>
                                </label>
                                <select asp-for="QuestionBankId" asp-items="ViewBag.QuestionBankId" required>
                                    <option value="">-- Select Question --</option>
                                </select>
                                <span asp-validation-for="QuestionBankId" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    The question this answer option will be available for.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">Answer Option</h3>

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="OptionText">
                                    Option Text
                                    <span class="required">*</span>
                                </label>
                                <input asp-for="OptionText" type="text" placeholder="e.g., Compliant" required />
                                <span asp-validation-for="OptionText" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    The text shown to the auditor when answering.
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="OptionValue">
                                    Option Value
                                    <span class="required">*</span>
                                </label>
                                <input asp-for="OptionValue" type="text" placeholder="e.g., compliant" required />
                                <span asp-validation-for="OptionValue" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    The underlying stored value for this option.
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="DisplayOrder">
                                    Display Order
                                    <span class="required">*</span>
                                </label>
                                <input asp-for="DisplayOrder" type="number" min="0" placeholder="e.g., 1" required />
                                <span asp-validation-for="DisplayOrder" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    Controls the order this option appears in relative to others.
                                </div>
                            </div>

                            <div class="form-group form-group-checkbox">
                                <label>
                                    <input asp-for="RequiresReason" type="checkbox" />
                                    Requires Reason
                                </label>
                                <div class="form-group-hint">
                                    When checked, selecting this option will prompt the auditor for a reason/comment.
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="form-main-footer">
                <a asp-action="Index" class="btn-cancel">
                    <i class="fas fa-times"></i>
                    Cancel
                </a>
                <button form="createOptionForm" type="submit" class="btn-submit">
                    <i class="fas fa-plus"></i>
                    Create Option
                </button>
            </div>
        </div>

        <div class="form-sidebar">
            <div class="form-sidebar-card">
                <h3>
                    <i class="fas fa-info-circle"></i>
                    Information
                </h3>
                <p>
                    Answer options are the selectable choices an auditor sees for Multiple Choice, Checklist, or Yes/No style questions.
                </p>
            </div>

            <div class="form-sidebar-card form-sidebar-help">
                <h3>
                    <i class="fas fa-question-circle"></i>
                    Need Help?
                </h3>
                <p>
                    Fields marked with <span class="required">*</span> are required. Enable "Requires Reason" for non-compliant options so auditors must explain their answer.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('createOptionForm');
            const inputs = form.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                const errorSpan = input.parentElement.querySelector('.form-group-error');
                if (errorSpan && errorSpan.textContent.trim()) {
                    input.closest('.form-group').classList.add('has-error');
                }
            });
            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    this.closest('.form-group').classList.remove('has-error');
                });
            });
        });
    </script>
}
