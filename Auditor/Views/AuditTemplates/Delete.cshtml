@model Auditor.ViewModels.AuditTemplate.AuditTemplateDeleteViewModel

@{
    ViewData["Title"] = "Delete Audit Template";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="list-container">
    <div class="list-header">
        <div class="list-header-content">
            <h1>🗑️ Delete Audit Template</h1>
            <p class="list-header-subtitle">This action cannot be undone.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="form-section">
        <div class="form-section-title">@Model.Name</div>
        <dl class="row">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Version</dt>
            <dd class="col-sm-9">v@(Model.Version)</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
            <dt class="col-sm-3">Created By</dt>
            <dd class="col-sm-9">@Model.CreatedByName</dd>
            <dt class="col-sm-3">Questions</dt>
            <dd class="col-sm-9">@Model.QuestionCount</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-submit btn-danger">Delete</button>
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </form>
    </div>
</div>
