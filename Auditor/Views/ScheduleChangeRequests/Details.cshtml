@model Auditor.Models.ScheduleChangeRequest

@{
    ViewData["Title"] = "Change Request Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Change Request Details</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Schedule</dt>
    <dd class="col-sm-9">
        @if (Model.Schedule != null)
        {
            <a asp-controller="AuditSchedules" asp-action="Details" asp-route-id="@Model.Schedule.Id">
                @Model.Schedule.Template?.Name @@ @Model.Schedule.Site?.Name
            </a>
        }
    </dd>

    <dt class="col-sm-3">Requested By</dt>
    <dd class="col-sm-9">@(Model.RequestedByNavigation?.DisplayName ?? "Unknown")</dd>

    <dt class="col-sm-3">Reason</dt>
    <dd class="col-sm-9" style="white-space: pre-wrap;">@Model.Reason</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Escalation Level</dt>
    <dd class="col-sm-9">@(Model.EscalationLevel ?? 0)</dd>

    <dt class="col-sm-3">Requested Date</dt>
    <dd class="col-sm-9">@Model.RequestDate.ToString("MMM dd, yyyy HH:mm")</dd>

    @if (Model.DecisionDate != null)
    {
        <dt class="col-sm-3">Decision Date</dt>
        <dd class="col-sm-9">@Model.DecisionDate?.ToString("MMM dd, yyyy HH:mm")</dd>

        <dt class="col-sm-3">Authorizer</dt>
        <dd class="col-sm-9">@(Model.Authorizer?.DisplayName ?? "Unknown")</dd>
    }
</dl>

@if (Model.Status == "Pending")
{
    <form asp-action="Authorize" asp-route-id="@Model.Id" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <div class="form-group mb-2">
            <label>Decision Notes (optional)</label>
            <textarea name="decisionNotes" class="form-control"></textarea>
        </div>
        <button type="submit" name="approve" value="true" class="btn btn-success">Approve</button>
        <button type="submit" name="approve" value="false" class="btn btn-danger">Reject</button>
    </form>
}

<div>
    <a asp-action="Index">Back to List</a>
</div>
