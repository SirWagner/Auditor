@model IEnumerable<Auditor.Models.QuestionCategory>

@{
    ViewData["Title"] = "Question Categories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="list-container">
    <div class="list-header">
        <div class="list-header-content">
            <h1>🗂️ Question Categories</h1>
            <p class="list-header-subtitle">Organize audit questions into standardized categories</p>
        </div>

        <a asp-action="Create" class="btn-list-primary">
            <span>+</span> Create New Category
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="list-table-wrapper">
            <table class="list-table table">
                <thead>
                    <tr>
                        <th style="width:30%;">Category Name</th>
                        <th style="width:50%;">Description</th>
                        <th style="width:20%;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="cell-name">
                                    <i class="fas fa-folder text-primary"></i> @item.Name
                                </div>
                            </td>

                            <td>
                                <div class="cell-secondary">
                                    @(string.IsNullOrWhiteSpace(item.Description)
                                        ? "No description provided."
                                        : item.Description)
                                </div>
                            </td>

                            <td>
                                <div class="list-actions">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view">View</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="list-table-wrapper">
            <div class="list-empty-state">
                <div class="empty-state-icon">🗂️</div>
                <h2 class="empty-state-title">No Categories Found</h2>
                <p class="empty-state-text">Create your first question category to organize audit questions.</p>

                <a asp-action="Create" class="btn-list-primary">
                    <span>+</span> Create First Category
                </a>
            </div>
        </div>
    }
</div>