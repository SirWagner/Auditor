@model Auditor.Models.QuestionBank

@{
    ViewData["Title"] = "Edit Question";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="list-container">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Question Bank</a></li>
        <li class="breadcrumb-item active">Edit Question</li>
    </ol>
</nav>

<div class="list-container">
    <div class="form-wrapper">

        <!-- Header -->
        <div class="mb-4">
            <h1 class="h2 d-flex align-items-center gap-2">
                <i class="fas fa-edit text-primary"></i>
                Edit Audit Question
            </h1>
            <p class="list-header-subtitle mb-0">
                Update this question's wording, category, and expected standard.
            </p>
        </div>

        <hr class="mb-4" />

        <!-- Form -->
        <form asp-action="Edit" method="post" class="form-content">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedBy" />
            <input type="hidden" asp-for="CreatedDate" />

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert">
                <strong>Please correct the following errors:</strong>
            </div>

            <!-- Question Text -->
            <div class="mb-3">
                <label asp-for="QuestionText" class="form-label fw-semibold">
                    <i class="fas fa-comment-dots text-primary me-1"></i>
                    Question Text
                </label>
                <textarea asp-for="QuestionText" class="form-control" rows="4"
                          placeholder="Enter the audit question..." required></textarea>
                <span asp-validation-for="QuestionText" class="text-danger small"></span>
            </div>

            <!-- Category + Type -->
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold">
                        <i class="fas fa-folder-open text-primary me-1"></i>
                        Category
                    </label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="ViewBag.CategoryId" required>
                        <option value="">-- Select a category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="QuestionTypeId" class="form-label fw-semibold">
                        <i class="fas fa-list text-primary me-1"></i>
                        Question Type
                    </label>
                    <select asp-for="QuestionTypeId" class="form-select"
                            asp-items="ViewBag.QuestionTypeId" required>
                        <option value="">-- Select a type --</option>
                    </select>
                    <span asp-validation-for="QuestionTypeId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Service Standard -->
            <div class="mt-3">
                <label asp-for="ServiceStandardRecommendation" class="form-label fw-semibold">
                    <i class="fas fa-star text-warning me-1"></i>
                    Service Standard Recommendation
                </label>
                <textarea asp-for="ServiceStandardRecommendation"
                          class="form-control"
                          rows="3"
                          placeholder="Describe expected service standard..." required></textarea>
                <div class="form-text">
                    Provide guidance on what constitutes compliance.
                </div>
                <span asp-validation-for="ServiceStandardRecommendation" class="text-danger small"></span>
            </div>

            <!-- Contractor -->
            <div class="mt-3">
                <label asp-for="ResponsibleContractor" class="form-label fw-semibold">
                    <i class="fas fa-user-tie text-primary me-1"></i>
                    Responsible Contractor/Department
                </label>
                <input asp-for="ResponsibleContractor"
                       class="form-control"
                       placeholder="Enter responsible entity" required />
                <div class="form-text">
                    Who is accountable for this audit area.
                </div>
                <span asp-validation-for="ResponsibleContractor" class="text-danger small"></span>
            </div>

            <!-- Active status -->
            <div class="mt-3 form-check">
                <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                <label class="form-check-label fw-semibold" asp-for="IsActive">
                    Active
                </label>
                <div class="form-text">
                    Inactive questions can no longer be added to new templates.
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a asp-action="Index" class="btn btn-secondary-action">
                    <i class="fas fa-arrow-left me-1"></i>
                    Cancel
                </a>

                <button type="submit" class="btn btn-list-primary">
                    <i class="fas fa-check-circle me-1"></i>
                    Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
