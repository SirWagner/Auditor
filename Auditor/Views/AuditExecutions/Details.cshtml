@model Auditor.Models.AuditExecution

@{
    ViewData["Title"] = "Audit Execution Details";
    Layout = "~/Views/Shared/_LayoutExec.cshtml";
}

<h2>Audit Execution Details</h2>

<hr />

<!-- 🔵 FINALIZE BUTTON -->
@if (Model.Status == "COMPLETED")
{
    <div class="mb-3">
        <button class="btn btn-success"
                onclick="finalizeAudit(@Model.Id)">
            Finalize Audit
        </button>
    </div>
}

<!-- EXECUTION SUMMARY -->
<div class="card mb-4">
    <div class="card-body">

        <h5>Execution Summary</h5>

        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Original Audit Date:</strong> @Model.OriginalAuditDate</p>
        <p><strong>Acceptance Date:</strong> @Model.AcceptanceDate</p>
        <p><strong>Submission Date:</strong> @Model.SubmissionDate</p>
        <p><strong>Rejection Reason:</strong> @Model.RejectionReason</p>

        <p><strong>Site:</strong> @Model.Schedule?.Site?.Name</p>
        <p><strong>Template:</strong> @Model.Schedule?.Template?.Name</p>

    </div>
</div>

<!-- RESPONSES -->
<h4>Responses</h4>

@foreach (var response in Model.AuditResponses)
{
    <div class="card mb-3">
        <div class="card-body">

            <p>
                <strong>Question:</strong>
                @response.TemplateItem?.QuestionBank?.QuestionText
            </p>

            <p>
                <strong>Compliant:</strong>
                @response.Compliant
            </p>

            <p>
                <strong>Comment:</strong>
                @response.Comment
            </p>

            <p>
                <strong>Selected Option:</strong>
                @response.SelectedOption?.OptionText
            </p>

            @if (response.Reasons.Any())
            {
                <p><strong>Reasons:</strong></p>
                <ul>
                    @foreach (var reason in response.Reasons)
                    {
                        <li>@reason.ReasonText</li>
                    }
                </ul>
            }

        </div>
    </div>
}

<!-- ATTACHMENTS -->
@if (Model.AuditAttachments.Any())
{
    <h4>Attachments</h4>

    <ul>
        @foreach (var file in Model.AuditAttachments)
        {
            <li>
                <a href="@file.FileUrl" target="_blank">
                    @file.FileName
                </a>
            </li>
        }
    </ul>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>
</div>

@section Scripts {

    <script>

        function finalizeAudit(id) {

            Swal.fire({
                title: 'Finalize Audit?',
                text: "This will close the audit permanently.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, finalize it'
            }).then((result) => {

                if (!result.isConfirmed) return;

                fetch('/AuditExecution/Finalize', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ id: id })
                })
                    .then(res => res.json())
                    .then(data => {

                        if (data.success) {

                            Swal.fire('Finalized!', '', 'success')
                                .then(() => location.reload());

                        } else {

                            Swal.fire('Error', data.message, 'error');
                        }

                    });

            });
        }

    </script>
}