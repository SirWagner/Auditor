@model Auditor.ViewModels.AuditTemplate.AuditTemplateCreateViewModel

<div class="card shadow-sm">

    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <strong>Questions (<span id="questionCount">0</span>)</strong>

        <button type="button"
                class="btn btn-sm btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#questionBankModal">
                <span class="bi bi-plus-circle"></span> Add from Question Bank
        </button>
    </div>

    <div class="card-body">
        <div id="questionContainer" class="questions-list">
            <div class="text-muted text-center py-4">
                No questions added yet. Click the button above to add questions.
            </div>
        </div>
    </div>

</div>

<style>
    #questionContainer {
        min-height: 100px;
    }

    #questionContainer.has-questions .text-muted {
        display: none;
    }
</style>

<script>
    // Update question count when questions change
    const updateQuestionCount = () => {
        const count = document.querySelectorAll("#questionContainer > .card").length;
        document.getElementById("questionCount").textContent = count;
        
        const container = document.getElementById("questionContainer");
        if (count > 0) {
            container.classList.add("has-questions");
        } else {
            container.classList.remove("has-questions");
        }
    };

    // Watch for changes
    const observer = new MutationObserver(updateQuestionCount);
    document.addEventListener("DOMContentLoaded", () => {
        observer.observe(document.getElementById("questionContainer"), {
            childList: true,
            subtree: true
        });
        updateQuestionCount();
    });
</script>
