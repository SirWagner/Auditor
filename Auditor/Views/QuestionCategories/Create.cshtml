@model Auditor.Models.QuestionCategory

@{
    ViewData["Title"] = "Create Question Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-page-container">
    <div class="form-page-breadcrumb">
        <a asp-controller="Template" asp-action="Dashboard">Dashboard</a>
        <span>›</span>
        <a asp-controller="QuestionCategories" asp-action="Index">Question Categories</a>
        <span>›</span>
        <span>Create New</span>
    </div>

    <div class="form-page-title-section">
        <div class="form-page-title-content">
            <h1>Create Question Category</h1>
            <p>Group related questions together for easier organization in the question bank</p>
        </div>
        <div class="form-page-meta">
            <span class="form-meta-badge">New Entry</span>
        </div>
    </div>

    <div class="form-wrapper">
        <div class="form-main">
            <div class="form-main-header">
                <h2>
                    <i class="fas fa-folder-open"></i>
                    Category Details
                </h2>
            </div>

            <div class="form-main-content">
                <form asp-action="Create" method="post" novalidate id="createQuestionCategoryForm">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="validation-alert">
                            <h3>
                                <i class="fas fa-times-circle"></i>
                                Form Validation Errors
                            </h3>
                            <ul>
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <div class="form-section">
                        <h3 class="form-section-title">Basic Information</h3>

                        <div class="form-grid full">
                            <div class="form-group">
                                <label asp-for="Name">
                                    Name
                                    <span class="required">*</span>
                                </label>
                                <input asp-for="Name" type="text" placeholder="e.g., Safety, Cleanliness, Security" required />
                                <span asp-validation-for="Name" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    A short, unique name identifying this category.
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Description">Description</label>
                                <input asp-for="Description" type="text" placeholder="e.g., Questions relating to passenger safety procedures" />
                                <span asp-validation-for="Description" class="form-group-error"></span>
                                <div class="form-group-hint">
                                    Optional context to help others understand what belongs in this category.
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="form-main-footer">
                <a asp-action="Index" class="btn-cancel">
                    <i class="fas fa-times"></i>
                    Cancel
                </a>
                <button form="createQuestionCategoryForm" type="submit" class="btn-submit">
                    <i class="fas fa-plus"></i>
                    Create Category
                </button>
            </div>
        </div>

        <div class="form-sidebar">
            <div class="form-sidebar-card">
                <h3>
                    <i class="fas fa-info-circle"></i>
                    Information
                </h3>
                <p>
                    Categories group similar questions together in the question bank, making templates easier to build and questions easier to find.
                </p>
            </div>

            <div class="form-sidebar-card form-sidebar-help">
                <h3>
                    <i class="fas fa-question-circle"></i>
                    Need Help?
                </h3>
                <p>
                    Fields marked with <span class="required">*</span> are required.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('createQuestionCategoryForm');
            const inputs = form.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                const errorSpan = input.parentElement.querySelector('.form-group-error');
                if (errorSpan && errorSpan.textContent.trim()) {
                    input.closest('.form-group').classList.add('has-error');
                }
            });
            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    this.closest('.form-group').classList.remove('has-error');
                });
            });
        });
    </script>
}
