@using Auditor.ViewModels.AuditTemplate

@model AuditTemplateEditViewModel

@{
    ViewData["Title"] = "Edit Audit Template";
}

<partial name="_AuditTemplateWizard" model="Model"/>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        window.__AUDIT_TEMPLATE_DATA__ = {
            questionBank: @Html.Raw(Json.Serialize(Model.QuestionBank)),
        };
    </script>

    <script type="module" src="~/js/audit-template/question-manager.js"></script>
    <script type="module" src="~/js/audit-template/stepper.js"></script>
    <script type="module" src="~/js/audit-template/init.js"></script>
}