<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Auditor</title>
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Site & Application Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Auditor.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/azia-details.css" asp-append-version="true" />

    <!-- Azia Template Styles -->
    <link rel="stylesheet" href="@Url.Content("~/Azia/css/azia.css")" />
    
    <!-- Icon Libraries -->
    <link rel="stylesheet" href="@Url.Content("~/Azia/lib/fontawesome-free/css/all.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Azia/lib/ionicons/css/ionicons.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Azia/lib/typicons.font/typicons.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Azia/lib/flag-icon-css/css/flag-icon.min.css")" />
    
    <!-- Theme & Custom Styles -->
    <link rel="stylesheet" href="~/css/theme.css" />
    
    <!-- Auditor Header - ISOLATED STYLES (no conflicts with page content) -->
    <link rel="stylesheet" href="~/css/header.css" />
    <link rel="stylesheet" href="~/css/auditor-forms.css" />
    <link rel="stylesheet" href="~/css/auditor-details.css" />

    @* 

    TODO: This breaks the design
    <link href="~/claudedesign/appusers.css" rel="stylesheet" /> *@
    <!-- In _Layout.cshtml -->
    <link rel="stylesheet" href="~/css/auditor-details-practical.css" />
    <link rel="stylesheet" href="~/css/auditor-details-related.css" />

    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-90680653-2"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'UA-90680653-2');
    </script>
</head>

<body>
    <!-- HEADER - Isolated with auditor-header-wrapper class -->
    <header class="auditor-header-wrapper">
        <div class="az-header">
            <div class="container-fluid">
                <!-- Header Left: Logo & Mobile Menu Toggle -->
                <div class="az-header-left">
                    <a asp-area="" asp-controller="Template" asp-action="dashboard" class="az-logo">
                        <i class="typcn typcn-radar"></i>
                        <span>Auditor</span>
                    </a>
                    <a href="#" id="azMenuShow" class="az-header-menu-icon d-lg-none">
                        <i class="fas fa-bars"></i>
                    </a>
                </div>
                
                <!-- Header Menu: Main Navigation -->
                <div class="az-header-menu" id="azHeaderMenu">
                    <ul class="nav">
                        <li class="nav-item">
                            <a asp-area="" asp-controller="Template" asp-action="dashboard" class="nav-link">
                                <i class="typcn typcn-th-large-outline"></i> Dashboard
                            </a>
                        </li>
                       
                        <li class="nav-item">
                            <a href="#" class="nav-link with-sub">
                                <i class="typcn typcn-plane-outline"></i> Airport
                            </a>
                            <nav class="az-menu-sub">
                                <a asp-area="" asp-controller="Airports" asp-action="Create" class="nav-link">
                                    <i class="typcn typcn-plus"></i> New Airport
                                </a>
                                <a asp-area="" asp-controller="Airports" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-th-list"></i> Airport List
                                </a>
                            </nav>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link with-sub">
                                <i class="typcn typcn-plane-outline"></i> Audit Sites
                            </a>
                            <nav class="az-menu-sub">
                                <a asp-area="" asp-controller="AuditSites" asp-action="Create" class="nav-link">
                                    <i class="typcn typcn-plus"></i> New Site
                                </a>
                                <a asp-area="" asp-controller="AuditSites" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-th-list"></i> Sites List
                                </a>
                            </nav>
                        </li>
                        
                        <li class="nav-item">
                            <a href="#" class="nav-link with-sub">
                                <i class="typcn typcn-clipboard"></i> Audit Templates
                            </a>
                            <nav class="az-menu-sub">
                                <a asp-area="" asp-controller="QuestionBanks" asp-action="Create" class="nav-link">
                                    <i class="typcn typcn-document-add"></i> Add Question
                                </a>
                                <a asp-area="" asp-controller="AuditTemplates" asp-action="Create" class="nav-link">
                                    <i class="typcn typcn-document-add"></i> New Template
                                </a>
                                <a asp-area="" asp-controller="AuditTemplates" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-folder"></i> Template List
                                </a>
                            </nav>
                        </li>
                        
                        <li class="nav-item">
                            <a href="#" class="nav-link with-sub">
                                <i class="typcn typcn-flash-outline"></i> Executions
                            </a>
                            <nav class="az-menu-sub">
                                <a asp-area="" asp-controller="AuditSchedules" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-calendar-outline"></i> Scheduled
                                </a>
                                <a asp-area="" asp-controller="AuditExecutions" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-media-play-outline"></i> In Progress
                                </a>
                                <a asp-area="" asp-controller="ScheduleChangeRequests" asp-action="Index" class="nav-link">
                                    <i class="typcn typcn-refresh-outline"></i> Change Requests
                                </a>
                            </nav>
                        </li>
                    </ul>
                </div>
                
                <!-- Header Right: Actions & Profile -->
                <div class="az-header-right">
                    <a href="#" class="az-header-search-link" title="Search">
                        <i class="fas fa-search"></i>
                    </a>
                    
                    <div class="az-header-message">
                        <a href="#" title="Messages">
                            <i class="typcn typcn-mail"></i>
                        </a>
                    </div>
                    
                    <div class="dropdown az-header-notification">
                        <a href="#" class="new" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                            <i class="typcn typcn-bell"></i>
                        </a>
                    </div>
                    
                    <div class="dropdown az-profile-menu">
                        <a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" class="az-img-user">
                            <img src="~/Azia/img/faces/face1.jpg" alt="Profile">
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a href="#" class="dropdown-item">
                                    <i class="typcn typcn-user-outline"></i> My Profile
                                </a>
                                <a href="#" class="dropdown-item">
                                    <i class="typcn typcn-cog-outline"></i> Account Settings
                                </a>
                                <hr />
                                <partial name="_LoginPartial" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>


        <!-- CONTENT WRAPPER - Isolated from header styles -->
        <div class="auditor-content-wrapper">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <!-- FOOTER -->
        @await Html.PartialAsync("_Footer")

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script src="~/Azia/lib/jquery/jquery.min.js"></script>
        <script src="~/Azia/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="~/Azia/lib/jquery.flot/jquery.flot.js"></script>
        <script src="~/Azia/lib/jquery.flot/jquery.flot.resize.js"></script>
        <script src="~/Azia/lib/chart.js/Chart.bundle.min.js"></script>
        <script src="~/js/pagination.js"></script>
        <!-- Auditor Header Mobile Menu Toggle Script -->
        <script>
            document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('azMenuShow');
            const headerMenu = document.getElementById('azHeaderMenu');

            if (menuToggle && headerMenu) {
            menuToggle.addEventListener('click', function(e) {
            e.preventDefault();
            headerMenu.classList.toggle('show');
            });

            // Close menu when a link is clicked
            const navLinks = headerMenu.querySelectorAll('.nav-link');
            navLinks.forEach(link => {
            link.addEventListener('click', function() {
            headerMenu.classList.remove('show');
            });
            });
            }

            // Close menu when clicking outside
            document.addEventListener('click', function(e) {
            if (headerMenu && menuToggle &&
            !headerMenu.contains(e.target) &&
            !menuToggle.contains(e.target)) {
            headerMenu.classList.remove('show');
            }
            });
            });
        </script>

        <script src="~/Azia/js/azia.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>
