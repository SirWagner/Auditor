@model Auditor.ViewModels.AuditTemplate.AuditTemplateCreateViewModel

<div class="list-table-wrapper p-0">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom">
        <div class="d-flex align-items-center gap-3">
            <h5 class="mb-0 fw-semibold">Questions</h5>

            <span id="questionCount"
                  class="cell-badge">
                0
            </span>
        </div>

        <button type="button"
                class="btn-list-primary"
                data-bs-toggle="modal"
                data-bs-target="#questionBankModal">
            <i class="bi bi-plus-circle"></i>
            Add Question
        </button>
    </div>

    <!-- BODY -->
    <div class="p-4">

        <div id="questionContainer" class="questions-container">

            <!-- EMPTY STATE -->
            <div id="emptyState" class="list-empty-state">
                <div class="empty-state-icon">🧩</div>
                <div class="empty-state-title">No Questions Added</div>
                <div class="empty-state-text">
                    Start building your audit by selecting questions from the bank.
                </div>

                <button type="button"
                        class="btn-list-primary"
                        data-bs-toggle="modal"
                        data-bs-target="#questionBankModal">
                    Add First Question
                </button>
            </div>

        </div>

    </div>
</div>