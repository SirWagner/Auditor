@model Auditor.ViewModels.AuditExecution.AuditExecutionRenderViewModel

@{
    ViewData["Title"] = "Execute Audit";
    Layout = "~/Views/Shared/_LayoutExec.cshtml";
}


<style>
    /* ============================= */
/* AUDIT EXECUTION FLOATING CARD */
/* ============================= */

.audit-exec-wrapper {
    display: flex;
    justify-content: center;
    padding: 2.5rem 1rem;
    background: #f6f7fb; /* subtle contrast background */
}

.audit-exec-card {
    width: 100%;
    max-width: 900px; /* tablet perfect width */
    background: #ffffff;
    border-radius: 18px;
    padding: 2.2rem;

    /* ✅ PURPLE GLOW FLOAT EFFECT */
    box-shadow:
        0 18px 40px rgba(120, 0, 255, 0.18),
        0 0 35px rgba(190, 140, 255, 0.35);

    position: relative;
}

/* Inner question cards */
.audit-exec-card .card {
    border-radius: 14px;
    border: 1px solid #eee;
}

/* Headings */
.audit-exec-card h2 {
    font-weight: 700;
}

.audit-exec-card h4 {
    margin-bottom: 0.5rem;
}



    .audit-exec-card {
        padding: 1.25rem;
        border-radius: 14px;
    }
}
</style>

<!-- ✅ PAGE WRAPPER -->
<div class="audit-exec-wrapper">

    <!-- ✅ FLOATING CARD -->
    <div class="audit-exec-card">

        <h2 class="text-center">@Model.AuditName</h2>
        <h4 class="text-center text-muted">Site: @Model.SiteName</h4>

        <hr />

        <div class="mb-3">
            <button type="button"
                    class="btn btn-outline-secondary"
                    onclick="window.history.back();">
                ← Back
            </button>
        </div>

        <form id="auditForm" enctype="multipart/form-data">

            @foreach (var question in Model.Questions)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">

                        <h5>
                            @question.QuestionText
                            @if (question.IsMandatory)
                            {
                                <span class="text-danger">*</span>
                            }
                        </h5>

                        @await Html.PartialAsync(
                            $"~/Views/AuditExecutions/Components/_" +
                            question.QuestionTypeName +
                            ".cshtml",
                            question)

                        <!-- ✅ ATTACHMENTS -->
                        <div class="mt-3">
                            <label class="form-label">Attachments</label>

                            <div class="d-flex gap-2 mb-1">
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm"
                                        onclick="document.getElementById('fileInput-@question.TemplateItemId').click()">
                                    📎 Choose Files
                                </button>

                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        onclick="document.getElementById('photoInput-@question.TemplateItemId').click()">
                                    📷 Take Photo
                                </button>
                            </div>

                            <input type="file"
                                   id="fileInput-@question.TemplateItemId"
                                   name="questionAttachments[@question.TemplateItemId][]"
                                   multiple
                                   class="d-none" />

                            <input type="file"
                                   id="photoInput-@question.TemplateItemId"
                                   name="questionAttachments[@question.TemplateItemId][]"
                                   accept="image/*"
                                   capture="environment"
                                   class="d-none" />

                            <small class="text-muted"
                                   id="fileNames-@question.TemplateItemId"></small>
                        </div>

                    </div>
                </div>
            }

            <div class="mt-4 text-center d-flex gap-2 justify-content-center">
                <button type="button"
                        class="btn btn-outline-secondary px-4"
                        onclick="saveDraft(@Model.ExecutionId)">
                    💾 Save Draft
                </button>
                <button type="button"
                        class="btn btn-success px-5"
                        onclick="submitAudit(@Model.ExecutionId)">
                    ✅ @(Model.Status == "REJECTED" ? "Resubmit Audit" : "Submit Audit")
                </button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        window.__AUDIT_EXECUTION_STATUS__ = "@Model.Status";
    </script>
    <script src="~/js/audit-render.js"></script>

    <!-- ✅ FILE NAME PREVIEW -->
    <script>
        document.querySelectorAll("input[type='file']").forEach(input => {
            input.addEventListener("change", () => {
                const id = input.id.split('-')[1];
                const label = document.getElementById("fileNames-" + id);

                if (label && input.files.length > 0) {
                    label.innerText = [...input.files].map(f => f.name).join(", ");
                }
            });
        });
    </script>
}