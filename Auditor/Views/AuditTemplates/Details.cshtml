@model Auditor.ViewModels.AuditTemplate.AuditTemplateDetailsViewModel

@{
    ViewData["Title"] = "Audit Template Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="details-page-container">

    <!-- =========================
         HERO (HEADER + OVERVIEW FUSED)
    ========================== -->
    <div class="azia-hero-card">

        <div class="azia-hero-left">

            <div class="azia-icon">
                <i class="fas fa-clipboard-list"></i>
            </div>

            <div>
                <h2 class="azia-title">@Model.Name</h2>

                <div class="azia-subtitle">
                    Version <strong>@Model.Version</strong>
                    · ID @Model.Version
                    · Created by <strong>@Model.CreatedBy</strong>
                </div>

            </div>

        </div>

        <div class="azia-hero-right">

            <span class="azia-badge @(Model.IsActive ? "success" : "danger")">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>

            <span class="azia-stat">
                <i class="fas fa-list"></i>
                @Model.Items.Count Questions
            </span>

        </div>

    </div>

    <!-- =========================
         MAIN LAYOUT
    ========================== -->
    <div class="azia-layout">

        <!-- LEFT NAV -->
        <div class="azia-vtabs">

            <button class="azia-tab active" data-tab="questions">
                <i class="fas fa-list"></i>
                Questions
            </button>

            <button class="azia-tab" data-tab="config">
                <i class="fas fa-cogs"></i>
                Configuration
            </button>pdate 

          @*   <button class="azia-tab" data-tab="meta">
                <i class="fas fa-database"></i>
                Metadata
            </button> *@

        </div>

        <!-- RIGHT CONTENT -->
        <div class="azia-content">

            <!-- QUESTIONS -->
            <div class="azia-panel active" id="questions">

                <div class="azia-grid">

                    @foreach (var item in Model.Items.OrderBy(x => x.Sequence))
                    {
                        <div class="azia-card hover">

                            <div class="azia-card-header">
                                <strong>#@item.Sequence</strong>

                                <span class="azia-badge @(item.Mandatory ? "success" : "muted")">
                                    @(item.Mandatory ? "Mandatory" : "Optional")
                                </span>
                            </div>

                            <div class="azia-card-body">
                                @item.QuestionText
                            </div>

                            <div class="azia-card-footer">
                                Category: @item.Category
                            </div>

                        </div>
                    }

                </div>

            </div>

            <!-- CONFIG -->
            <div class="azia-panel" id="config">

                <div class="azia-card">

                    <div class="azia-card-title">
                        Configuration
                    </div>

                    <div class="azia-info-grid">
                        @* <div>Users: <strong>@(Model.Users?.Count ?? 0)</strong></div> *@
                        <div>Question Bank: <strong>@(Model.Items?.Count ?? 0)</strong></div>
                    </div>

                </div>

            </div>


        </div>

    </div>
</div>

<!-- =========================
     SCRIPT (REUSABLE)
========================= -->
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const tabs = document.querySelectorAll(".azia-tab");
            const panels = document.querySelectorAll(".azia-panel");

            tabs.forEach(tab => {
                tab.addEventListener("click", () => {

                    tabs.forEach(t => t.classList.remove("active"));
                    panels.forEach(p => p.classList.remove("active"));

                    tab.classList.add("active");
                    document.getElementById(tab.dataset.tab).classList.add("active");

                });
            });

        });
    </script>
}