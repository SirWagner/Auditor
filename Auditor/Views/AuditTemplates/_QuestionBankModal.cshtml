@model Auditor.ViewModels.AuditTemplate.AuditTemplateCreateViewModel

<div class="modal fade" id="questionBankModal" tabindex="-1" aria-labelledby="questionBankModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="questionBankModalLabel">Select Questions to Add</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <div class="input-group mb-3">
                    <span class="input-group-text">
                        <span class="bi bi-search"></span>
                    </span>
                    <input type="text"
                           id="questionSearch"
                           class="form-control"
                           placeholder="Search questions by name or description..."
                           aria-label="Search questions" />
                </div>

                <div id="questionBankList" class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    <!-- Rendered by JavaScript -->
                </div>

                <div id="noPendingQuestions" class="text-muted text-center py-4" style="display: none;">
                    No questions available or all questions already added.
                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted">Click a question to add it to the template</small>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>

    </div>
</div>

<style>
    #questionBankList .list-group-item {
        cursor: pointer;
        transition: background-color 0.15s ease-in-out;
        padding: 0.75rem 1rem;
        border: none;
        border-bottom: 1px solid #dee2e6;
    }

    #questionBankList .list-group-item:last-child {
        border-bottom: none;
    }

    #questionBankList .list-group-item:hover {
        background-color: #e7f1ff;
        border-left: 4px solid #0d6efd;
        padding-left: calc(1rem - 4px);
    }

    #questionBankList .list-group-item:active {
        background-color: #cfe2ff;
    }

    #questionBankList .list-group-item.already-added {
        opacity: 0.5;
        cursor: not-allowed;
        background-color: #f8f9fa;
    }

    #questionBankList .list-group-item.already-added:hover {
        background-color: #f8f9fa;
        border-left: none;
        padding-left: 1rem;
    }
</style>
