@model Auditor.ViewModels.QuestionBank.QuestionBankCreateViewModel

@{
	ViewData["Title"] = "Create Question";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-page-container">
	<!-- Breadcrumb -->
	<nav class="form-breadcrumb" aria-label="breadcrumb">
		<ol class="breadcrumb mb-0">
			<li class="breadcrumb-item"><a asp-controller="Template" asp-action="Dashboard">Dashboard</a></li>
			<li class="breadcrumb-item"><a asp-action="Index">Question Bank</a></li>
			<li class="breadcrumb-item active">Create Question</li>
		</ol>
	</nav>

	<div class="form-card">
		<!-- Header -->
		<div class="form-header">
			<div>
				<h1><i class="fas fa-plus-circle text-primary"></i> Create Audit Question</h1>
				<p>Add a question to the airport audit question bank.</p>
			</div>
		</div>

		<form id="questionCreateForm" asp-action="Create" method="post">
			@Html.AntiForgeryToken()

			<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

			<!-- Question -->
			<div class="form-group">
				<label asp-for="QuestionText"><i class="fas fa-comment-dots"></i> Question Text</label>
				<textarea asp-for="QuestionText" class="form-control" rows="4" placeholder="Enter audit question"></textarea>
				<span asp-validation-for="QuestionText"></span>
			</div>

			<div class="row">
				<div class="col-md-6">
					<div class="form-group">
						<label asp-for="CategoryId"><i class="fas fa-folder"></i> Category</label>
						<select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
							<option value="">Select category</option>
						</select>
						<span asp-validation-for="CategoryId"></span>
					</div>
				</div>

				<div class="col-md-6">
					<div class="form-group">
						<label asp-for="QuestionTypeId"><i class="fas fa-list"></i> Question Type</label>
						<select asp-for="QuestionTypeId" class="form-select" asp-items="ViewBag.QuestionTypeId">
							<option value="">Select type</option>
						</select>
						<span asp-validation-for="QuestionTypeId"></span>
					</div>
					<div id="checklist-section" class="mt-4" style="display:none;">

						<div class="card">

							<div class="card-header">
								<i class="fas fa-list-check"></i>
								Checklist Items
							</div>


							<div class="card-body">

								<div id="checklist-items">
								</div>


								<button type="button"
										id="add-checklist-item"
										class="btn btn-outline-primary">

									<i class="fas fa-plus"></i>
									Add Item

								</button>

							</div>

						</div>

					</div>
				</div>

			</div>

			<div class="form-group">
				<label asp-for="ServiceStandardRecommendation"><i class="fas fa-star"></i> Service Standard Recommendation</label>
				<textarea asp-for="ServiceStandardRecommendation" class="form-control" rows="3" placeholder="Expected compliance standard"></textarea>
				<small>Define what compliance looks like.</small>
				<span asp-validation-for="ServiceStandardRecommendation"></span>
			</div>

			<div class="form-group">
				<label asp-for="ResponsibleContractor"><i class="fas fa-user-tie"></i> Responsible Contractor / Department</label>
				<input asp-for="ResponsibleContractor" class="form-control" placeholder="Responsible entity" />
				<small>Person or department accountable.</small>
				<span asp-validation-for="ResponsibleContractor"></span>
			</div>

			<div class="form-group">
				<label asp-for="CreatedBy"><i class="fas fa-user"></i> Audit Coordinator</label>
				<select asp-for="CreatedBy" class="form-select" asp-items="ViewBag.CreatedBy">
					<option value="">Select auditor</option>
				</select>
				<span asp-validation-for="CreatedBy"></span>
			</div>

			<div class="form-actions">
				<a asp-action="Index" class="btn btn-secondary-action"><i class="fas fa-arrow-left"></i> Cancel</a>
				<button type="submit" class="btn btn-list-primary"><i class="fas fa-check-circle"></i> Create Question</button>
			</div>
		</form>

		<div class="form-tip">
			<i class="fas fa-info-circle"></i> Questions should be clear, measurable and aligned with airport standards.
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script type="module" src="~/js/auditor/question-create.js"></script>
}