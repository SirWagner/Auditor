@model Auditor.Models.AuditExecution

@{
    ViewData["Title"] = "Edit Audit Execution";
    Layout = "~/Views/Shared/_LayoutExec.cshtml";
}

<div class="form-page-container">
    <div class="form-page-breadcrumb">
        <a asp-controller="Template" asp-action="Dashboard">Dashboard</a>
        <span>›</span>
        <a asp-controller="AuditExecutions" asp-action="Index">Audit Executions</a>
        <span>›</span>
        <span>Edit</span>
    </div>

    <div class="form-page-title-section">
        <div class="form-page-title-content">
            <h1>Edit Audit Execution</h1>
            <p>Manually correct an execution record</p>
        </div>
        <div class="form-page-meta">
            <span class="form-meta-badge">Editing</span>
        </div>
    </div>

    <div class="form-wrapper">
        <div class="form-main">
            <div class="form-main-header">
                <h2>
                    <i class="typcn typcn-flash-outline"></i>
                    Execution Details
                </h2>
            </div>

            <div class="form-main-content">
                <form asp-action="Edit" method="post" novalidate id="editExecutionForm">
                    <input type="hidden" asp-for="Id" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="validation-alert">
                            <h3>
                                <i class="fas fa-times-circle"></i>
                                Form Validation Errors
                            </h3>
                            <ul>
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <div class="form-section">
                        <h3 class="form-section-title">Assignment</h3>

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="ScheduleId">
                                    Schedule
                                    <span class="required">*</span>
                                </label>
                                <select asp-for="ScheduleId" asp-items="ViewBag.ScheduleId" required></select>
                                <span asp-validation-for="ScheduleId" class="form-group-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="AuditorId">
                                    Auditor
                                    <span class="required">*</span>
                                </label>
                                <select asp-for="AuditorId" asp-items="ViewBag.AuditorId" required></select>
                                <span asp-validation-for="AuditorId" class="form-group-error"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">Status &amp; Dates</h3>
                        <p class="form-section-description">
                            Prefer the Accept/Reject/Submit/Finalize actions on the execution's Details page over editing status here directly.
                        </p>

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="Status">
                                    Status
                                    <span class="required">*</span>
                                </label>
                                <select asp-for="Status" required>
                                    <option value="PENDING_ACCEPTANCE">PENDING_ACCEPTANCE</option>
                                    <option value="IN_PROGRESS">IN_PROGRESS</option>
                                    <option value="COMPLETED">COMPLETED</option>
                                    <option value="CLOSED">CLOSED</option>
                                    <option value="REJECTED">REJECTED</option>
                                </select>
                                <span asp-validation-for="Status" class="form-group-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="OriginalAuditDate">
                                    Original Audit Date
                                    <span class="required">*</span>
                                </label>
                                <input asp-for="OriginalAuditDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" required />
                                <span asp-validation-for="OriginalAuditDate" class="form-group-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="AcceptanceDate">Acceptance Date</label>
                                <input asp-for="AcceptanceDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" />
                                <span asp-validation-for="AcceptanceDate" class="form-group-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="SubmissionDate">Submission Date</label>
                                <input asp-for="SubmissionDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" />
                                <span asp-validation-for="SubmissionDate" class="form-group-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="RejectionReason">Rejection Reason</label>
                                <input asp-for="RejectionReason" type="text" />
                                <span asp-validation-for="RejectionReason" class="form-group-error"></span>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="form-main-footer">
                <a asp-action="Index" class="btn-cancel">
                    <i class="fas fa-times"></i>
                    Cancel
                </a>
                <button form="editExecutionForm" type="submit" class="btn-submit">
                    <i class="fas fa-save"></i>
                    Save Changes
                </button>
            </div>
        </div>

        <div class="form-sidebar">
            <div class="form-sidebar-card">
                <h3>
                    <i class="fas fa-info-circle"></i>
                    Information
                </h3>
                <p>
                    Audit executions track the lifecycle of a scheduled audit from acceptance through submission.
                </p>
            </div>

            <div class="form-sidebar-card form-sidebar-help">
                <h3>
                    <i class="fas fa-question-circle"></i>
                    Need Help?
                </h3>
                <p>
                    Fields marked with <span class="required">*</span> are required.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('editExecutionForm');
            const inputs = form.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                const errorSpan = input.parentElement.querySelector('.form-group-error');
                if (errorSpan && errorSpan.textContent.trim()) {
                    input.closest('.form-group').classList.add('has-error');
                }
            });
            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    this.closest('.form-group').classList.remove('has-error');
                });
                input.addEventListener('change', function () {
                    this.closest('.form-group').classList.remove('has-error');
                });
            });
        });
    </script>
}
