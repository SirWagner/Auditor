@model Auditor.Models.AuditSchedule

@{
    ViewData["Title"] = "Audit Schedule Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="details-page-container">


    <!-- Breadcrumb -->
    <div class="details-breadcrumb">

        <a asp-controller="Template"
           asp-action="Dashboard">
            Dashboard
        </a>

        <span>›</span>

        <a asp-action="Index">
            Audit Schedules
        </a>

        <span>›</span>

        <span>
            Schedule #@Model.Id
        </span>

    </div>



    <!-- Compact Header -->
    <div class="details-header">


        <div>

            <h1>
                Audit Schedule #@Model.Id
            </h1>


            <div class="text-muted small mt-1">

                Created:
                @Model.CreatedDate.ToString("MMM dd, yyyy")

                <span class="mx-2">•</span>

                Scheduled:
                @Model.ScheduledDate.ToString("MMM dd, yyyy")

            </div>


        </div>



        <div class="details-header-actions">


            <a asp-controller="AuditExecutions"
               asp-action="Start"
               asp-route-scheduleId="@Model.Id"
               class="btn-details-primary">

                <i class="fas fa-play"></i>

                Start Audit

            </a>



            <a asp-action="Index"
               class="btn-details-secondary">

                <i class="fas fa-arrow-left"></i>

                Back

            </a>


        </div>


    </div>




    <!-- Main Information -->
    <div class="details-info-card">


        <div class="details-info-card-header">

            <h2>
                Audit Schedule Information
            </h2>

        </div>



        <div class="details-info-card-body">


            <div class="details-info-grid">


                <div class="details-info-field">

                    <div class="details-info-label">
                        Audit Template
                    </div>

                    <div class="details-info-value">

                        <strong>
                            @Model.Template?.Name
                        </strong>

                    </div>

                </div>




                <div class="details-info-field">

                    <div class="details-info-label">
                        Audit Site
                    </div>

                    <div class="details-info-value">

                        <strong>
                            @Model.Site?.Name
                        </strong>

                    </div>

                </div>





                <div class="details-info-field">

                    <div class="details-info-label">
                        Assigned Auditor
                    </div>

                    <div class="details-info-value">

                        @Model.Scheduler?.DisplayName

                    </div>

                </div>





                <div class="details-info-field">

                    <div class="details-info-label">
                        Due Date
                    </div>

                    <div class="details-info-value">

                        <strong>
                            @Model.DueDate.ToString("MMM dd, yyyy")
                        </strong>

                    </div>

                </div>




                <div class="details-info-field">

                    <div class="details-info-label">
                        Status
                    </div>


                    <div class="details-info-value">

                        @{
                            var statusClass = Model.Status switch
                            {
                                "SCHEDULED" => "active",
                                "COMPLETED" => "active",
                                "CANCELLED" => "inactive",
                                _ => "warning"
                            };
                        }


                        <span class="details-status-badge @statusClass">

                            @Model.Status

                        </span>


                    </div>

                </div>




                <div class="details-info-field">

                    <div class="details-info-label">
                        Created Date
                    </div>


                    <div class="details-info-value">

                        @Model.CreatedDate.ToString("MMM dd, yyyy")

                    </div>

                </div>



            </div>


        </div>


    </div>





    <!-- Execution Section -->
    <div class="details-section mt-4">


        <h2 class="details-section-title">

            Audit Execution

        </h2>



        <div class="details-info-card">


            <div class="details-info-card-body">


                <p class="text-muted mb-0">

                    This schedule is ready for execution. Start the audit when the assigned auditor is prepared.

                </p>


            </div>


        </div>


    </div>



</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}