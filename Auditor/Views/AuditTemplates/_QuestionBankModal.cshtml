@model Auditor.ViewModels.AuditTemplate.AuditTemplateCreateViewModel

<div class="modal fade" id="questionBankModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">

        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header border-bottom">
                <div>
                    <h5 class="modal-title fw-semibold">Question Bank</h5>
                    <small class="text-muted">Select questions to include in your audit</small>
                </div>

                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <!-- SEARCH -->
                <div class="list-search mb-3">
                    <input type="text"
                           id="questionSearch"
                           class="form-control"
                           placeholder="Search questions..." />
                </div>

                <!-- LIST -->
                <div id="questionBankList" class="question-bank-list">
                    <!-- JS renders -->
                </div>

                <!-- EMPTY -->
                <div id="noPendingQuestions" class="list-empty-state d-none">
                    <div class="empty-state-icon">📭</div>
                    <div class="empty-state-title">No Questions Found</div>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <small class="text-muted">Click a question to add it</small>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>