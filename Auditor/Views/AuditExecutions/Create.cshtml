@model Auditor.Models.AuditExecution

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_LayoutExec.cshtml";
}

<h1>Create</h1>

<h4>AuditExecution</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ScheduleId" class="control-label"></label>
                <select asp-for="ScheduleId" class ="form-control" asp-items="ViewBag.ScheduleId"></select>
            </div>
            <div class="form-group">
                <label asp-for="AuditorId" class="control-label"></label>
                <select asp-for="AuditorId" class ="form-control" asp-items="ViewBag.AuditorId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AcceptanceDate" class="control-label"></label>
                <input asp-for="AcceptanceDate" class="form-control" />
                <span asp-validation-for="AcceptanceDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RejectionReason" class="control-label"></label>
                <input asp-for="RejectionReason" class="form-control" />
                <span asp-validation-for="RejectionReason" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SubmissionDate" class="control-label"></label>
                <input asp-for="SubmissionDate" class="form-control" />
                <span asp-validation-for="SubmissionDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OriginalAuditDate" class="control-label"></label>
                <input asp-for="OriginalAuditDate" class="form-control" />
                <span asp-validation-for="OriginalAuditDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
